    "better-comments.multilineComments": true,
    // NOTE: Install extension `@ext:edwinhuish.better-comments-next` for these to work
    "better-comments.strict": false,
    "better-comments.tags": [
        //! module-level rustdoc
        {
            "tag": "!",
            "color": "#FF7D7D",
        },
        //? I almost never use this
        {
            "tag": "?",
            "color": "#34C8EB",
        },
        // regular comment
        // // commented-out comment. Leave all settings for documentation purposes
        {
            "tag": "//",
            "color": "#707070",
            "strikethrough": true,
            "underline": false,
            "backgroundColor": "transparent",
            "bold": false,
            "italic": false,
        },
        /// # Safety
        /// A safety text section in conventional rustdoc markdown
        {
            // SAFETY: Conventional C++/Rust inline safety comment. The next line of code looks sus but trust me it is fine
            "tag": ["safe", "# safe", "\\safe", "@safe"],
            "color": "#FF3333",
            "bold": true,
        },
        /// # Panic
        /// The following jsonc does not panic, that was just a test of a conventional rustdoc panic heading
        {
            // PANIC: I labeled this 'panic' instead of 'panics' because some ppl write it singular for some reason.
            // \throws: exceptions
            "tag": ["panic", "# panic", "\\throw", "@throw"],
            "color": "#CD9CFF",
        },

        /*
         * TODO: Make multi-line comments work
         * This would be great!
         */
        // TODO: This background color is OK, decide if the contrast is helpful or nah
        {
            // @todo This is a javadoc-style todo
            "tag": ["todo", "@todo", "# todo", "\\todo"],
            "color": "#FF8C00",
            "backgroundColor": "#1A1A10",
        },
        // FIXME: If I eventually end up porting my ultra-legibility MPLAB theme to vscode,
        //        I will have to change these colors
        {
            "tag": ["fix", "# fix", "@fix", "\\fix"],
            "color": "#FFD400",
            "backgroundColor": "#1A1A10",
            "bold": true,
        },
        {
            "tag": ["hack"],
            "color": "#9B59B6",
            "backgroundColor": "#181B22",
        },
    ],
